<?xml version="1.0" encoding="utf-8"?>
<!--
  Phase 9 Security: Network Security Config.
  - يمنع cleartext HTTP بالكامل (HTTPS only).
  - يُعرّف نطاقات موثوقة (Supabase + Firebase) مع مرجع لـcertificate pinning مستقبلي.
  - مرجع: docs/LOGIC_SPEC.md §5
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- نطاقات Supabase + FCM -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">supabase.co</domain>
        <domain includeSubdomains="true">supabase.in</domain>
        <domain includeSubdomains="true">firebaseapp.com</domain>
        <domain includeSubdomains="true">googleapis.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
        <!--
          📌 لتفعيل Certificate Pinning مستقبلاً:
          <pin-set expiration="2027-01-01">
              <pin digest="SHA-256">BASE64_HASH_HERE</pin>
              <pin digest="SHA-256">BACKUP_HASH_HERE</pin>
          </pin-set>
        -->
    </domain-config>

    <!-- debug overrides — للاختبار المحلي فقط -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
